Subject: [PATCH 1021/1487] > run NEMU ysyx_22040000 xyzabc Linux xyzabc
 6.8.0-117-generic #117~22.04.1-Ubuntu SMP PREEMPT_DYNAMIC Thu May  7 22:17:46
 UTC  x86_64 x86_64 x86_64 GNU/Linux  15:43:39 up  1:36,  1 user,  load
 average: 0.34, 0.22, 0.15

---
 abstract-machine/am/src/platform/nemu/ioe/timer.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/abstract-machine/am/src/platform/nemu/ioe/timer.c b/abstract-machine/am/src/platform/nemu/ioe/timer.c
index 5a2ca38..05de73c 100644
--- a/abstract-machine/am/src/platform/nemu/ioe/timer.c
+++ b/abstract-machine/am/src/platform/nemu/ioe/timer.c
@@ -5,10 +5,11 @@
 void __am_timer_init() {
 }
 
+//由于在nemu中的timer是在offset=4的时候才获取真实事件，所以应该先访问高32
 void __am_timer_uptime(AM_TIMER_UPTIME_T *uptime) {
   //从RTC_ADDR处获取长度为8字节的MMIO空间，来获取64位当前的时间
-  uint32_t low = inl(RTC_ADDR);
   uint32_t high = inl(RTC_ADDR + 4);
+  uint32_t low = inl(RTC_ADDR);
   uptime->us = ((uint64_t)high << 32) | low;
 }
 
