Subject: [PATCH 0582/1487] > compile NEMU ysyx_22040000 xyzabc Linux xyzabc
 6.8.0-117-generic #117~22.04.1-Ubuntu SMP PREEMPT_DYNAMIC Thu May  7 22:17:46
 UTC  x86_64 x86_64 x86_64 GNU/Linux  16:48:27 up  1:18,  1 user,  load
 average: 0.20, 0.14, 0.07

---
 abstract-machine/scripts/platform/nemu.mk | 3 ++-
 testall.sh                                | 2 +-
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/abstract-machine/scripts/platform/nemu.mk b/abstract-machine/scripts/platform/nemu.mk
index 58a5896..9ada6b2 100644
--- a/abstract-machine/scripts/platform/nemu.mk
+++ b/abstract-machine/scripts/platform/nemu.mk
@@ -12,7 +12,8 @@ CFLAGS    += -I$(AM_HOME)/am/src/platform/nemu/include
 LDSCRIPTS += $(AM_HOME)/scripts/linker.ld
 LDFLAGS   += --defsym=_pmem_start=0x80000000 --defsym=_entry_offset=0x0
 LDFLAGS   += --gc-sections -e _start
-NEMUFLAGS += -l $(shell dirname $(IMAGE).elf)/nemu-log.txt
+##打开 -b 选项来打开批处理模式
+NEMUFLAGS += -l $(shell dirname $(IMAGE).elf)/nemu-log.txt -b
 
 MAINARGS_MAX_LEN = 64
 MAINARGS_PLACEHOLDER = the_insert-arg_rule_in_Makefile_will_insert_mainargs_here
diff --git a/testall.sh b/testall.sh
index 0730588..0ea9303 100755
--- a/testall.sh
+++ b/testall.sh
@@ -29,7 +29,7 @@ for file in tests/*.c; do
   # 一旦在此期间检测到 "is not implemented" 或者 Makefile 自带的 FAIL 报错，
   # awk 会悄悄记下标记 err=1，并在结束流时返回退出了状态码 1。
   # 因为我们加了 set -o pipefail 和 set -e，一旦状态为 1，整个脚本都会干净利落地中止。
-  echo -e "c\nq" | make ARCH=riscv32-nemu ALL="$name" run | awk '{print} /is not implemented/ || /\*\*\*FAIL\*\*\*/ {err=1} END{exit err}'
+  echo -e "q" | make ARCH=riscv32-nemu ALL="$name" run | awk '{print} /is not implemented/ || /\*\*\*FAIL\*\*\*/ {err=1} END{exit err}'
 
   # 由于配置了 set -e 和 pipefail，只有当上一条测试完美通过时，脚本才会继续执行到这里。
   # 此时自动清理该测试及其相关的由 AM 框架生成的产物 (通常带有前缀 $name-)。
-- 
