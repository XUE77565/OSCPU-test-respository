+import os, sys, pathlib, subprocess
+
+f = pathlib.Path(sys.argv[1])
+try:
+    objcopy = os.getenv('CROSS_COMPILE', '') + 'objcopy'
+    data = subprocess.run(
+        [objcopy, '-S', '-O', 'binary', '-j', '.text', f, '/dev/stdout'],
+        capture_output=True).stdout
+    assert len(data) <= 510
