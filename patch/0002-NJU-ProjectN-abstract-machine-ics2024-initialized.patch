diff --git a/abstract-machine/scripts/linker.ld b/abstract-machine/scripts/linker.ld
new file mode 100644
index 0000000..8ae8f5c
--- /dev/null
+++ b/abstract-machine/scripts/linker.ld
@@ -0,0 +1,33 @@
+ENTRY(_start)
+PHDRS { text PT_LOAD; data PT_LOAD; }
+
+SECTIONS {
+  /* _pmem_start and _entry_offset are defined in LDFLAGS */
+  . = _pmem_start + _entry_offset;
+  .text : {
+    *(entry)
+    *(.text*)
+  } : text
+  etext = .;
+  _etext = .;
+  .rodata : {
+    *(.rodata*)
+  }
+  .data : {
+    *(.data*)
+  } : data
+  edata = .;
+  _data = .;
+  .bss : {
+	_bss_start = .;
+    *(.bss*)
+    *(.sbss*)
+    *(.scommon)
+  }
+  _stack_top = ALIGN(0x1000);
+  . = _stack_top + 0x8000;
+  _stack_pointer = .;
+  end = .;
+  _end = .;
+  _heap_start = ALIGN(0x1000);
+}
