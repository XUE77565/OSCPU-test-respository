+  .text : {
+    *(entry)
+    *(.text*)
+  }
+  etext = .;
+  _etext = .;
+  .rodata : {
+    *(.rodata*)
+  }
+  .htif : {
+    PROVIDE(__htif_base = . );
+    *(.htif)
+  }
+  .data : {
+    *(.data)
+  }
+  edata = .;
