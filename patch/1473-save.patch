-           ref->pc, dut->pc);
-    pass = false;
-  }
+  // NPC 是流水线设计, sim_get_pc() 返回 IF 阶段 PC 而非下一条 PC,
+  // 所以不直接比较 PC。PC 正确性间接由 GPR 比对保证 (如 JAL 写 pc+4 到 rd)。
   return pass;
 }
 
