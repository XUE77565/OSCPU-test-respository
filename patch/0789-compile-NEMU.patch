From 207b8e0f1d683b3dc9b9f627fdb828e811b62807 Mon Sep 17 00:00:00 2001
From: tracer-ysyx <tracer@ysyx.org>
Date: Tue, 26 May 2026 20:04:41 +0800
Subject: [PATCH 0789/1487] > compile NEMU ysyx_22040000 xyzabc Linux xyzabc
 6.8.0-117-generic #117~22.04.1-Ubuntu SMP PREEMPT_DYNAMIC Thu May  7 22:17:46
 UTC  x86_64 x86_64 x86_64 GNU/Linux  20:04:41 up 20 min,  1 user,  load
 average: 0.10, 0.21, 0.16

---
 nemu/Kconfig            | 10 ++++++++++
 nemu/Makefile           |  1 +
 nemu/src/memory/paddr.c | 12 ++++++++++--
 3 files changed, 21 insertions(+), 2 deletions(-)

diff --git a/nemu/Kconfig b/nemu/Kconfig
index f9395ee..73d1890 100644
--- a/nemu/Kconfig
+++ b/nemu/Kconfig
@@ -157,6 +157,16 @@ config ITRACE_COND
   string "Only trace instructions when the condition is true"
   default "true"
 
+config MTRACE
+  depends on TRACE
+  bool "Enable memory tracer"
+  default y
+
+config MTRACE_COND
+  depends on MTRACE
+  string "Only trace memory when the condition is true"
+  default "true"
+
 
 config DIFFTEST
   depends on TARGET_NATIVE_ELF
diff --git a/nemu/Makefile b/nemu/Makefile
index 87c2da8..684feda 100644
--- a/nemu/Makefile
+++ b/nemu/Makefile
@@ -49,6 +49,7 @@ CFLAGS_BUILD += $(if $(CONFIG_CC_LTO),-flto,)
 CFLAGS_BUILD += $(if $(CONFIG_CC_DEBUG),-Og -ggdb3,)
 CFLAGS_BUILD += $(if $(CONFIG_CC_ASAN),-fsanitize=address,)
 CFLAGS_TRACE += -DITRACE_COND=$(if $(CONFIG_ITRACE_COND),$(call remove_quote,$(CONFIG_ITRACE_COND)),true)
+CFLAGS_TRACE += -DMTRACE_COND=$(if $(CONFIG_MTRACE_COND),$(call remove_quote,$(CONFIG_MTRACE_COND)),true)
 CFLAGS  += $(CFLAGS_BUILD) $(CFLAGS_TRACE) -D__GUEST_ISA__=$(GUEST_ISA)
 LDFLAGS += $(CFLAGS_BUILD)
 
diff --git a/nemu/src/memory/paddr.c b/nemu/src/memory/paddr.c
index b8a3d69..6d3581d 100644
--- a/nemu/src/memory/paddr.c
+++ b/nemu/src/memory/paddr.c
@@ -51,7 +51,11 @@ void init_mem() {
 }
 
 word_t paddr_read(paddr_t addr, int len) {
-  printf("paddr_read: addr = " FMT_PADDR ", len = %d\n", addr, len);
+#ifdef CONFIG_MTRACE_COND
+  if (MTRACE_COND) {
+    printf("paddr_read: addr = " FMT_PADDR ", len = %d\n", addr, len);
+  }
+#endif
   if (likely(in_pmem(addr))) return pmem_read(addr, len);
   IFDEF(CONFIG_DEVICE, return mmio_read(addr, len));
   out_of_bound(addr);
@@ -59,7 +63,11 @@ word_t paddr_read(paddr_t addr, int len) {
 }
 
 void paddr_write(paddr_t addr, int len, word_t data) {
-  printf("paddr_write: addr = " FMT_PADDR ", len = %d, data = " FMT_WORD "\n", addr, len, data);
+#ifdef CONFIG_MTRACE_COND
+  if (MTRACE_COND) {
+    printf("paddr_write: addr = " FMT_PADDR ", len = %d, data = " FMT_WORD "\n", addr, len, data);
+  }
+#endif
   if (likely(in_pmem(addr))) { pmem_write(addr, len, data); return; }
   IFDEF(CONFIG_DEVICE, mmio_write(addr, len, data); return);
   out_of_bound(addr);
-- 
