diff --git a/npc/csrc/main.cpp b/npc/csrc/main.cpp
index c47fb8a..0f2923d 100644
--- a/npc/csrc/main.cpp
+++ b/npc/csrc/main.cpp
@@ -4,7 +4,9 @@
 #include <string.h>
 #include <sys/time.h>
 
-#define ITRACE 1
+#define ITRACE 0
+#define DIFFTEST 1
+#define MTRACE 0
 
 // Verilator 头文件
 #include "Vcustom_cpu.h"
@@ -95,7 +97,9 @@ extern "C" int pmem_read(int raddr) {
   // DEBUG: 追踪对栈区域的读取
   if (addr >= 0x80008fd0 && addr <= 0x80009000) {
     int val = in_pmem(addr) ? *(int32_t *)guest_to_host(addr) : 0;
-    printf("[LOAD ] addr=0x%08x val=0x%08x\n", addr, (uint32_t)val);
+    if(ITRACE){
+      printf("[LOAD ] addr=0x%08x val=0x%08x\n", addr, (uint32_t)val);
+    }
   }
 
   // 时钟 MMIO: 返回当前时间(微秒)
@@ -139,7 +143,9 @@ extern "C" void pmem_write(int waddr, int wdata, int wmask) {
   if (in_pmem(addr)) {
     // DEBUG: 追踪对栈区域的写入 (sp 附近)
     if (addr >= 0x80008fd0 && addr <= 0x80009000) {
-      printf("[STORE] addr=0x%08x data=0x%08x mask=0x%02x\n", addr, (uint32_t)wdata, (uint8_t)wmask);
+      if(MTRACE){
+        printf("[STORE] addr=0x%08x data=0x%08x mask=0x%02x\n", addr, (uint32_t)wdata, (uint8_t)wmask);
+      }
     }
     uint8_t *p = guest_to_host(addr);
     uint8_t *data_bytes = (uint8_t *)&wdata;
@@ -196,7 +202,9 @@ void sim_init(const char *bin_path) {
 
   // 初始化 DiffTest (加载 NEMU 参考实现)
   // NPC_HOME 由 Makefile 传入绝对路径
-  init_difftest("/home/xueyizhou/Desktop/ysyx/UCAS-COURSE-OpenXiangshan/nemu/build/riscv32-nemu-interpreter-so", g_img_size);
+  if(DIFFTEST){
+    init_difftest("/home/xueyizhou/Desktop/ysyx/UCAS-COURSE-OpenXiangshan/nemu/build/riscv32-nemu-interpreter-so", g_img_size);
+  }
 }
 
 // 推进一个时钟周期
@@ -316,7 +324,9 @@ void sim_exec(uint64_t n) {
         printf("0x%08x: Instruction retired, Instruction: %08x\n", sim_get_pc(), sim_get_inst());
       }
       // DiffTest: 与 NEMU 参考实现对比寄存器状态
-      difftest_step(sim_get_pc());
+      if(DIFFTEST){
+        difftest_step(sim_get_pc());
+      }
       // 检查 watchpoint
       if (check_watchpoints()) {
         npc_state.state = NPC_STOP;
