 abstract-machine/am/src/platform/nemu/ioe/gpu.c | 8 ++++++++
 nemu/src/device/vga.c                           | 6 ++++--
 2 files changed, 12 insertions(+), 2 deletions(-)

diff --git a/abstract-machine/am/src/platform/nemu/ioe/gpu.c b/abstract-machine/am/src/platform/nemu/ioe/gpu.c
index fb33096..7a07d61 100644
--- a/abstract-machine/am/src/platform/nemu/ioe/gpu.c
+++ b/abstract-machine/am/src/platform/nemu/ioe/gpu.c
@@ -4,6 +4,14 @@
 #define SYNC_ADDR (VGACTL_ADDR + 4)
 
 void __am_gpu_init() {
+  int i;
+  int w = io_read(AM_GPU_CONFIG).width;
+  int h = io_read(AM_GPU_CONFIG).height;
+  uint32_t *fb = (uint32_t *)(uintptr_t)FB_ADDR;
+  for(i = 0; i < w * h; i++) {
+    fb[i] = i;
+  }
+  outl(SYNC_ADDR, 1);
 }
 
 void __am_gpu_config(AM_GPU_CONFIG_T *cfg) {
diff --git a/nemu/src/device/vga.c b/nemu/src/device/vga.c
index e9ddac0..e41bc2a 100644
--- a/nemu/src/device/vga.c
+++ b/nemu/src/device/vga.c
@@ -72,8 +72,10 @@ static inline void update_screen() {
 #endif
 
 void vga_update_screen() {
-  // TODO: call `update_screen()` when the sync register is non-zero,
-  // then zero out the sync register
+  if(vgactl_port_base[0] == 1) {
+    vgactl_port_base[0] = 0;
+    IFDEF(CONFIG_VGA_SHOW_SCREEN, update_screen());
+  }
 }
 
 void init_vga() {
