diff --git a/abstract-machine/am/src/riscv/npc/cte.c b/abstract-machine/am/src/riscv/npc/cte.c
index 77a357c..61809d9 100644
--- a/abstract-machine/am/src/riscv/npc/cte.c
+++ b/abstract-machine/am/src/riscv/npc/cte.c
@@ -5,13 +5,18 @@
 static Context* (*user_handler)(Event, Context*) = NULL;
 
 Context* __am_irq_handle(Context *c) {
+  uint32_t cause = c->mcause;
   if (user_handler) {
     Event ev = {0};
-    switch (c->mcause) {
+    switch (cause) {
+      case 11: 
+        if((int)c->GPR1 == -1) {ev.event = EVENT_YIELD;}
+        else {ev.event = EVENT_SYSCALL;} break;
       default: ev.event = EVENT_ERROR; break;
     }
 
     c = user_handler(ev, c);
+    c->mepc += 4;  // ecall保存的是自身PC，需要跳到下一条指令
     assert(c != NULL);
   }
 
@@ -31,7 +36,16 @@ bool cte_init(Context*(*handler)(Event, Context*)) {
 }
 
 Context *kcontext(Area kstack, void (*entry)(void *), void *arg) {
-  return NULL;
+  //在栈底构造一个Context结构体
+  Context *cp = (Context *)(kstack.end - sizeof(Context));
+  //清零所有字段
+  memset(cp, 0, sizeof(Context));
+  //设置初始值
+  cp->mstatus = 0x1800;
+  cp->mepc = (uintptr_t)entry - 4; // 因为__am_irq_handle中会对mepc += 4，这里先减去4以抵消
+  //printf("[INFO]kcontext: entry = 0x%08x\n", cp->mepc);
+  cp->gpr[10] = (uintptr_t)arg;
+  return cp;
 }
 
 void yield() {
