-  while (cycle < MAX_CYCLES) {
+  while (1) {
     bool retired = sim_clock_step();
     cycle++;
 
@@ -341,6 +341,7 @@ void sim_exec(uint64_t n) {
              g_exit_code == 0 ? "\33[1;32mHIT GOOD TRAP\33[0m"
                               : "\33[1;31mHIT BAD TRAP\33[0m",
              sim_get_pc(), g_exit_code);
+      //打印出周期数
       return;
     }
 
