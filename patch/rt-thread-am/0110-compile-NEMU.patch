+  if(success == false) {
+    printf("Failed to evaluate expression: %s\n", args);
+    free_wp(wp);
+    return 0;
+  }
+  printf("Set watchpoint %d: %s = " FMT_WORD "\n", wp->NO, wp->expr, wp->old_value);
+  return 0;
+}
