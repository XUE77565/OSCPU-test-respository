---
 npc/Makefile   | 2 +-
 npc/vsrc/alu.v | 8 ++++----
 2 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/npc/Makefile b/npc/Makefile
index 13ca5a8..1fcf4a8 100644
--- a/npc/Makefile
+++ b/npc/Makefile
@@ -37,7 +37,7 @@ VERILATOR_FLAGS := --cc \
 	-I$(VSRC_DIR) \
 	--trace \
 	-Wno-TIMESCALEMOD \
-	# -Wno-fatal
+	-Wno-fatal
 
 # 传递给 C++ 编译器的选项
 # -I: 让 C++ 能 include sdb.h; -g: 调试信息; -O2: 优化
diff --git a/npc/vsrc/alu.v b/npc/vsrc/alu.v
index e4fb999..1e7b23f 100644
--- a/npc/vsrc/alu.v
+++ b/npc/vsrc/alu.v
@@ -32,10 +32,10 @@ module alu(
 	assign unsigned_B = 	{1'b0,B};
 	assign unsigend_sub   =	unsigned_A + ~unsigned_B + 1;
 
-	assign {CarryOut,Result} =  (ALUop == `AND)  ? A & B:
-                                (ALUop == `OR )  ? A | B:
-                                (ALUop == `XOR)  ? A ^ B:
-                                (ALUop == `NOR)  ? {1'b0,~(A | B)}:
+	assign {CarryOut,Result} =  (ALUop == `AND)  ? unsigned_A & unsigned_B:
+                                (ALUop == `OR )  ? unsigned_A | unsigned_B:
+                                (ALUop == `XOR)  ? unsigned_A ^ unsigned_B:
+                                (ALUop == `NOR)  ? {1'b0,~(unsigned_A | unsigned_B)}:
                                 (ALUop == `ADD)  ? A + B:
                                 (ALUop == `SUB)  ? A + ~B + 1:
                                 (ALUop == `SLT)  ? (({A[31],B[31]} == 2'b10) ? 1 : 
